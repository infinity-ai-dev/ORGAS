# ============================================================================
# ORGAS AI - Environment Variables Configuration
# ============================================================================
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to version control
# ============================================================================

# ============================================================================
# DATABASE - PostgreSQL/Supabase
# ============================================================================
POSTGRES_USER=supabase
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=postgres
POSTGRES_PORT=5432

# ============================================================================
# CACHE - Redis
# ============================================================================
REDIS_PASSWORD=redis_secure_password
REDIS_PORT=6379

# ============================================================================
# FRONTEND - Next.js
# ============================================================================
# These are passed to frontend container
# Already configured in docker-compose.yml

# ============================================================================
# BACKEND API - Express.js/TypeScript (infinitytools/orgas-api:2.0.44)
# ============================================================================

# Supabase Configuration
SUPABASE_ANON_KEY=eyJ0eXAiOiJKV1QiLCJhbGciOiJIUzI1NiJ9...
SUPABASE_SERVICE_KEY=eyJ0eXAiOiJKV1QiLCJhbGciOiJIUzI1NiJ9...

# Agent API Configuration (Python FastAPI Service)
AGENT_API_KEY=your_agent_api_key_here
# AGENT_API_URL is automatically set to http://orgas-ai-agents:8000/api
# AGENT_API_TIMEOUT default: 30000 (ms)

# JWT Configuration
JWT_SECRET=f1d703439bea0516e753919188777f64806d0a45

# ============================================================================
# AI AGENTS SERVICE - FastAPI/LangGraph (Python)
# ============================================================================

# LLM API Keys
GOOGLE_API_KEY=your_google_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Logging
LOG_LEVEL=INFO
ENVIRONMENT=production
DEBUG=false

# ============================================================================
# ADMIN TOOLS (Optional - Debug Profile)
# ============================================================================
PGADMIN_EMAIL=admin@orgas.local
PGADMIN_PASSWORD=admin
PGADMIN_PORT=5050
REDIS_COMMANDER_PORT=8081

# ============================================================================
# PORTS
# ============================================================================
API_PORT=3000
AGENTS_API_PORT=8000
POSTGRES_PORT=5432
REDIS_PORT=6379
