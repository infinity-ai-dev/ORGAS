# ═══════════════════════════════════════════════════════════════════════════════
# ORGAS AI Agent - Environment Configuration Template
# Version: 3.0.0
# Last Updated: 2026-03-04
# ═══════════════════════════════════════════════════════════════════════════════

# ─── FastAPI Server Configuration ──────────────────────────────────────────────
ENVIRONMENT=development
DEBUG=true
HOST=0.0.0.0
PORT=8000
WORKERS=4
LOG_LEVEL=INFO

# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/orgas_db

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_DB=0
REDIS_TTL_SECONDS=3600

# ─── LLM API Keys (Cascading Fallback System) ────────────────────────────────
# Primary LLM: Google Gemini 2.5 Flash
GOOGLE_API_KEY=your_google_api_key_here

# Fallback 1: OpenAI GPT-4 Turbo
OPENAI_API_KEY=your_openai_api_key_here

# Fallback 2: Grok/xAI (OpenAI-compatible API)
GROK_API_KEY=your_grok_api_key_from_xai_here
GROK_API_BASE=https://api.x.ai/openai/v1

# Optional: Anthropic Claude
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ─── LLM Model Configuration ──────────────────────────────────────────────────
# Primary Model: Google Gemini 2.5 Flash
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TEMPERATURE=0.2
GEMINI_MAX_TOKENS=4096

# Fallback 1: OpenAI GPT-4 Turbo
OPENAI_MODEL=gpt-4-turbo
OPENAI_TEMPERATURE=0.2
OPENAI_MAX_TOKENS=4096

# Fallback 2: Grok/xAI
GROK_MODEL=grok-1
GROK_TEMPERATURE=0.2
GROK_MAX_TOKENS=4096

# LLM Fallback Configuration
LLM_FALLBACK_ENABLED=true
LLM_FALLBACK_TIMEOUT=30

# Embedding Model
EMBEDDING_MODEL=text-embedding-3-small

# ─── LangGraph ───────────────────────────────────────────────────────────────
CHECKPOINT_DIR=./checkpoints
MAX_ITERATIONS=10
TIMEOUT_SECONDS=300

# ─── Semantic Memory ─────────────────────────────────────────────────────────
SEMANTIC_BUFFER_SIZE=10
SEMANTIC_SIMILARITY_THRESHOLD=0.7
SEMANTIC_MAX_CONTEXT_MESSAGES=20

# ─── RAG Pipeline ────────────────────────────────────────────────────────────
RAG_CHUNK_SIZE=1000
RAG_CHUNK_OVERLAP=200
RAG_RETRIEVAL_K=5
RAG_SCORE_THRESHOLD=0.6

# ─── Document Processing ────────────────────────────────────────────────────
MAX_DOCUMENT_SIZE_MB=50

# ─── Logging ─────────────────────────────────────────────────────────────────
LOG_FORMAT=json

# ─── Agent Configuration ──────────────────────────────────────────────────────
MAX_WORKERS=5
TIMEOUT_SECONDS=30
STORAGE_CACHE_TTL=3000

# ─── Database Configuration (Optional) ─────────────────────────────────────────
# Individual components (used if DATABASE_URL not set)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=orgas_db
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_SSL=false

# ─── Redis Configuration (Optional) ───────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# ─── Supabase Storage ──────────────────────────────────────────────────────────
SUPABASE_STORAGE_URL=https://your-supabase-instance.supabase.co/storage/v1
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ─── External Services Integration ────────────────────────────────────────────
HTML2PDF_URL=https://html2pdf.example.com/pdf
HTML2PDF_API_KEY=your_html2pdf_api_key_here

# ─── Development Features ─────────────────────────────────────────────────────
RUN_MIGRATIONS=false
RELOAD=false
DEBUG_MODE=false

# ─── Python Configuration ──────────────────────────────────────────────────────
PYTHONUNBUFFERED=1
PYTHONDONTWRITEBYTECODE=1
